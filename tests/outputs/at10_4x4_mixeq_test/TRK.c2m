PARAMETER TRKSSH TRKFILSSH TRKFLUXL1 TRKFILFLUXL1 TRKFLUXL2 TRKFILFLUXL2 tdtssh tdtfluxl1 tdtfluxl2 ::
::: LINKED_LIST TRKSSH ;
::: SEQ_BINARY TRKFILSSH ;
::: LINKED_LIST TRKFLUXL1 ;
::: SEQ_BINARY TRKFILFLUXL1 ;
::: LINKED_LIST TRKFLUXL2 ;
::: SEQ_BINARY TRKFILFLUXL2 ;
;

MODULE SALT: MCCGT: END: ;

* Tracking for step SSH
TRKSSH TRKFILSSH := SALT: tdtssh ::
    EDIT 2
    TITLE 'SSH - IC'
    ANIS 2
    TISO 8 25.0
    IC EPSJ 1.0E-5
;

* Tracking for step FLUXL1
TRKFLUXL1 TRKFILFLUXL1 := SALT: tdtfluxl1 ::
    EDIT 2
    TITLE 'FLUXL1 - IC'
    ANIS 2
    TISO 8 25.0
    IC EPSJ 1.0E-5
;

* Tracking for step FLUXL2
TRKFLUXL2 TRKFILFLUXL2 := SALT: tdtfluxl2 ::
    EDIT 2
    TITLE 'FLUXL2 - MOC'
    ANIS 2
    ALLG
    TSPC 12 20.0 REND
    NOIC
;

* MOC tracking for step FLUXL2
TRKFLUXL2 := MCCGT: TRKFLUXL2 TRKFILFLUXL2 ::
    EDIT 1
    GAUS 4 AAC 80 TMT EPSI 1E-5
;

END: ;
QUIT .
