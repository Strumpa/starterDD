* PROCEDURE TRK.c2m : tracking
* --------------------------------
* Procedure generated by starterDD
* --------------------------------
*    INPUT & OUTPUT PARAMETERS
* --------------------------------
PARAMETER TRKSSH TRKFILSSH TRKFLUXL1 TRKFILFLUXL1 TRKFLUXL2 TRKFILFLUXL2 tdt_ssh tdt_fluxl1 tdt_fluxl2 ::
::: LINKED_LIST TRKSSH ;
::: SEQ_BINARY TRKFILSSH ;
::: LINKED_LIST TRKFLUXL1 ;
::: SEQ_BINARY TRKFILFLUXL1 ;
::: LINKED_LIST TRKFLUXL2 ;
::: SEQ_BINARY TRKFILFLUXL2 ;
;

INTEGER o_anis ;
:: >>o_anis<< ;

MODULE SALT: MCCGT: END: ;

* Tracking for step SSH
TRKSSH TRKFILSSH := SALT: tdt_ssh ::
    EDIT 1
    TITLE 'SSH - IC'
    BATCH 200
    TISO EQW 8 25.0
    IC EPSJ 1.0E-5
;

* Tracking for step FLUXL1
TRKFLUXL1 TRKFILFLUXL1 := SALT: tdt_fluxl1 ::
    EDIT 1
    TITLE 'FLUXL1 - IC'
    BATCH 200
    TISO EQW 8 25.0
    IC EPSJ 1.0E-5
;

* Tracking for step FLUXL2
TRKFLUXL2 TRKFILFLUXL2 := SALT: tdt_fluxl2 ::
    EDIT 1
    TITLE 'FLUXL2 - MOC'
    ALLG LONG
    BATCH 2000
    GAUS
    ANIS <<o_anis>>
    TSPC EQW2 24 40.0 REND
    NOIC
;

* MOC tracking for step FLUXL2
TRKFLUXL2 := MCCGT: TRKFLUXL2 TRKFILFLUXL2 ::
    EDIT 1
    GAUS <<o_anis>> AAC 100 ILU0
    HDD 0.0 SC KRYL 10
;

END: ;
QUIT .
