MODULE LIB: G2S: SALT: MCCGT: USS: ASM: FLU: EDI: SPH: GREP: UTL: COMPO:
  DELETE: END: ;
PROCEDURE MIX TRK EDIR MIXEQ_FLUXL1 ;

LINKED_LIST LIBRARY LIBRARY2 TRKSSH TRKFLUXL1 TRKFLUXL2 SYS FLUXL1
  FLUXL2 EDITION LIBEQ COMPO PARAMS ;
SEQ_BINARY TRKFILSSH TRKFILFLUXL1 TRKFILFLUXL2 ;
STRING name_compo := "_CPO_AT10_4x4_mix_splitting" ;
STRING Draglib := "dummy_alias" ;
INTEGER o_anis := 4 ;
INTEGER n_Tfuel := 1 ;
INTEGER i_Tfuel := 0 ;
INTEGER n_Tcool := 1 ;
INTEGER i_Tcool := 0 ;
INTEGER n_DCool := 1 ;
INTEGER i_DCool := 0 ;
INTEGER n_dens := 1 ;
REAL TFuel ;
REAL TCool ;
REAL DCool ;
REAL N_H ;
REAL N_O ;
REAL keffL1 ;
REAL keffL2 ;
REAL TFUEL := 900.0 ;
REAL TBOX := 600.0 ;
REAL TCLAD := 600.0 ;
REAL TCOOL := 600.0 ;
REAL TMODE := 600.0 ;
REAL TCTRL := 600.0 ;

SEQ_ASCII tdt_ssh :: FILE 'AT10_4x4_mix_splitting_SSH_IC_TISO_MACRO.dat'
  ;
SEQ_ASCII tdt_fluxl1 :: FILE
  'AT10_4x4_mix_splitting_FLUXL1_IC_TISO_MACRO.dat' ;
SEQ_ASCII tdt_fluxl2 :: FILE
  'AT10_4x4_mix_splitting_FLUXL2_MOC_TSPC.dat' ;
SEQ_ASCII _COMPO :: FILE '_CPO_AT10_4x4_mix_splitting' ;

**************************************************
* Tracking sub-procedure call
**************************************************
TRKSSH TRKFILSSH TRKFLUXL1 TRKFILFLUXL1 TRKFLUXL2 TRKFILFLUXL2 := TRK
  tdt_ssh tdt_fluxl1 tdt_fluxl2 :: <<o_anis>> ;

**************************************************
* Parameter arrays for branch calculations
**************************************************
PARAMS := UTL: ::
    CREA
        fuel_temp <<n_Tfuel>> =
            750.0
    CREA
        cool_temp <<n_Tcool>> =
            559.0
    CREA
        cool_dens <<n_DCool>> =
            0.73669
;
PARAMS := UTL: PARAMS ::
    CREA
        N_H_arr <<n_dens>> =
            4.92517066E-02
    CREA
        N_O_arr <<n_dens>> =
            2.46258533E-02
;

**************************************************
* COMPO initialization
**************************************************
COMPO := COMPO: ::
   EDIT 0
   STEP UP 'EDIHOM_COND'
       MAXCAL 1
       COMM 'Condensed, homogenized over all fuel cells' ENDC
       PARA 'DCool' VALU REAL
       PARA 'TFuel' VALU REAL
       PARA 'TCool' VALU REAL
ISOT 12 U234 U235 U236 U238 Pu239 Pu240 Pu241 Pu242 Gd155 Gd157 Xe135
  Sm149
   INIT
   STEP UP 'EDIHOM_295'
       MAXCAL 1
       COMM 'Homogenized over all materials' ENDC
       PARA 'DCool' VALU REAL
       PARA 'TFuel' VALU REAL
       PARA 'TCool' VALU REAL
      ISOT 1 U238
   INIT
   STEP UP 'EDIR_2G'
       MAXCAL 1
       COMM 'Condensed to 2g, per pin homogenization' ENDC
       PARA 'DCool' VALU REAL
       PARA 'TFuel' VALU REAL
       PARA 'TCool' VALU REAL
      ISOT 6 U234 U235 U236 U238 Gd155 Gd157
   INIT
   STEP UP 'U238_295'
       MAXCAL 1
       COMM 'U238, 295g, homogenized over all fuel cells' ENDC
       PARA 'DCool' VALU REAL
       PARA 'TFuel' VALU REAL
       PARA 'TCool' VALU REAL
      ISOT 1 U238
   INIT
;

**************************************************
* Main loop over branch statepoints
**************************************************
WHILE i_Tfuel n_Tfuel < DO
    EVALUATE i_Tfuel := i_Tfuel 1 + ;
    GREP: PARAMS :: GETVAL 'fuel_temp' <<i_Tfuel>> >>TFuel<< ;
    WHILE i_Tcool n_Tcool < DO
        EVALUATE i_Tcool := i_Tcool 1 + ;
        GREP: PARAMS :: GETVAL 'cool_temp' <<i_Tcool>> >>TCool<< ;
        WHILE i_DCool n_DCool < DO
            EVALUATE i_DCool := i_DCool 1 + ;
            GREP: PARAMS :: GETVAL 'cool_dens' <<i_DCool>> >>DCool<< ;
            GREP: PARAMS :: GETVAL 'N_H_arr' <<i_DCool>> >>N_H<< ;
            GREP: PARAMS :: GETVAL 'N_O_arr' <<i_DCool>> >>N_O<< ;
            ECHO "State Point:" ;

            ECHO "TFuel=" TFuel "TCool=" TCool "DCool=" DCool ;

            EVALUATE TFUEL := TFuel ;
            EVALUATE TCOOL := TCool ;
            EVALUATE TMODE := TCool ;

            * LIB: creation
LIBRARY := MIX :: <<Draglib>> 'RSE' <<o_anis>> 'NONE' <<TFUEL>> <<TBOX>>
  <<TCLAD>> <<TCOOL>> <<TMODE>> <<TCTRL>> <<N_H>> <<N_O>> ;

            * USS: self-shielding
            LIBRARY2 := USS: LIBRARY TRKSSH TRKFILSSH ::
                EDIT 1 ARM
            ;

            * ASM: + FLU: — first level
            SYS := ASM: LIBRARY2 TRKFLUXL1 TRKFILFLUXL1 ::
                EDIT 1 ARM
            ;

            FLUXL1 := FLU: SYS LIBRARY2 TRKFLUXL1 TRKFILFLUXL1 ::
                EDIT 1 TYPE K
            ;
            GREP: FLUXL1 :: GETVAL 'K-EFFECTIVE' 1 1 1 >>keffL1<< ;
            ECHO "AT10_4x4_mix_splitting L1 keff=" keffL1 ;

            * EDI: energy condensation (L1 → coarse)
            EDITION := EDI: FLUXL1 LIBRARY2 TRKFLUXL1 ::
                EDIT 0
                MICR ALL
                MERG MIX
COND 10 14 18 26 33 40 49 56 66 84 150 210 241 244 247 252 255 258 261
  268 273 277 281 286 291
                SAVE ON COND26
            ;
            LIBEQ := EDITION :: STEP UP COND26 ;

            * SPH: equivalence correction
            LIBEQ := SPH: LIBEQ TRKFLUXL1 TRKFILFLUXL1 ::
                EDIT 1
                GRMAX 19
            ;

            * Cleanup L1
            FLUXL1 SYS EDITION := DELETE: FLUXL1 SYS EDITION ;

            * MIXEQ: FLUXL1 → FLUXL2
            LIBEQ := MIXEQ_FLUXL1 LIBEQ ;

            * ASM: + FLU: — second level
            SYS := ASM: LIBEQ TRKFLUXL2 TRKFILFLUXL2 ::
                ARM EDIT 1
            ;

            FLUXL2 := FLU: LIBEQ SYS TRKFLUXL2 TRKFILFLUXL2 ::
                EDIT 1 TYPE K
            ;
            GREP: FLUXL2 :: GETVAL 'K-EFFECTIVE' 1 1 1 >>keffL2<< ;
            ECHO "AT10_4x4_mix_splitting L2 keff=" keffL2 ;

            * EDI/COMPO call
COMPO := EDIR FLUXL2 LIBEQ TRKFLUXL2 COMPO :: <<name_compo>> <<TFuel>>
  <<TCool>> <<DCool>> ;

            * Cleanup
            LIBRARY LIBRARY2 LIBEQ := DELETE: LIBRARY LIBRARY2 LIBEQ ;
            FLUXL2 := DELETE: FLUXL2 ;
            SYS := DELETE: SYS ;
        ENDWHILE ;
        EVALUATE i_DCool := 0 ;
    ENDWHILE ;
    EVALUATE i_Tcool := 0 ;
ENDWHILE ;

**************************************************
* Export COMPO to file
**************************************************
_COMPO := COMPO ;

END: ;
QUIT .
